API_URL=http://localhost:4000
USERS=12
REQUEST_TIMEOUT_MS=5000
SUMMARY_INTERVAL_MS=60000
ATTACK_INTERVAL_MS=300000

# Safety-first defaults so simulator traffic does not interfere with regular app usage.
SAFE_MODE=true
RUN_DURATION_MS=180000
MAX_IN_FLIGHT=8
ENABLE_RUSH_HOUR=false
ALLOW_WRITE_NORMAL=false
ENABLE_BRUTE_FORCE=false
ATTACK_SCALE=1
ATTACK_PACING_MS=120
SIMULATOR_SOURCE=traffic-simulator
SIMULATOR_IP_FALLBACK=198.18.0.10
SIM_AUTH_HEADER=Authorization
SIM_AUTH_TOKEN=
EXCLUDED_ENDPOINT_PATTERNS=/api/auth/register,/api/settings,/api/block-ip,/api/unblock-ip,/api/alerts/reset
